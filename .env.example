# ─── App ─────────────────────────────────────────────────────────
APP_SECRET_KEY=your-super-secret-key-change-this
APP_ENV=development
BASE_URL=http://localhost:8000

# ─── Database ────────────────────────────────────────────────────
DATABASE_URL=sqlite+aiosqlite:///./loan_wizard.db
# For production PostgreSQL:
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/loan_wizard

# ─── LLM ─────────────────────────────────────────────────────────
GEMINI_API_KEY=AIzaSyDY2XAQKpKb4e6ZolwD7GmmxUHBxlPvuUA
LLM_MODEL=gemini-1.5-flash

# ─── STT ─────────────────────────────────────────────────────────
STT_PROVIDER=whisper          # "whisper" (local) or "deepgram"
DEEPGRAM_API_KEY=your-deepgram-key

# ─── Storage (optional – for video recordings) ───────────────────
AWS_ACCESS_KEY_ID=your-aws-key
AWS_SECRET_ACCESS_KEY=your-aws-secret
S3_BUCKET=loan-wizard-recordings
S3_REGION=ap-south-1

# ─── JWT ─────────────────────────────────────────────────────────
JWT_ALGORITHM=HS256
JWT_EXPIRE_MINUTES=60
